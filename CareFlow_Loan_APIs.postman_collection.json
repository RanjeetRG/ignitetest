{
  "info": {
    "_postman_id": "c1a2b3c4-d5e6-7f8a-9b0c-1d2e3f4a5b6c",
    "name": "CareFlow Customer & Loan v1 APIs",
    "description": "Postman Collection for testing v1 Login, Apply Loan, My Applications, and Validation Test Cases (missing amount, invalid income, unauthorized role).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Customer Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "var jsonData = pm.response.json();",
              "pm.test(\"Token received\", function () {",
              "    pm.expect(jsonData.token).to.not.be.undefined;",
              "});",
              "pm.environment.set(\"customer_token\", jsonData.token);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"customer\",\n  \"password\": \"demo123\"\n}"
        },
        "url": {
          "raw": "http://localhost:5000/api/v1/auth/login",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5000",
          "path": ["api", "v1", "auth", "login"]
        }
      }
    },
    {
      "name": "2. Doctor Login (For Unauthorized Role Test)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "var jsonData = pm.response.json();",
              "pm.environment.set(\"doctor_token\", jsonData.token);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"doctor\",\n  \"password\": \"demo123\"\n}"
        },
        "url": {
          "raw": "http://localhost:5000/api/v1/auth/login",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5000",
          "path": ["api", "v1", "auth", "login"]
        }
      }
    },
    {
      "name": "3. Apply Loan API (Success)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 201\", function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "var jsonData = pm.response.json();",
              "pm.test(\"Loan created successfully\", function () {",
              "    pm.expect(jsonData.loan.amount).to.eql(20000);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{customer_token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"amount\": 20000,\n  \"purpose\": \"Home Improvement\",\n  \"monthly_income\": 5500\n}"
        },
        "url": {
          "raw": "http://localhost:5000/api/v1/loans/apply",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5000",
          "path": ["api", "v1", "loans", "apply"]
        }
      }
    },
    {
      "name": "4. Customer Loan List API",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "var jsonData = pm.response.json();",
              "pm.test(\"Applications list returned\", function () {",
              "    pm.expect(jsonData.applications).to.be.an('array');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{customer_token}}" }
        ],
        "url": {
          "raw": "http://localhost:5000/api/v1/loans/my-applications",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5000",
          "path": ["api", "v1", "loans", "my-applications"]
        }
      }
    },
    {
      "name": "5. Validation: Missing Amount",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 400 for missing amount\", function () {",
              "    pm.response.to.have.status(400);",
              "});",
              "var jsonData = pm.response.json();",
              "pm.test(\"Error message indicates missing amount\", function () {",
              "    pm.expect(jsonData.error).to.include(\"Missing loan amount\");",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{customer_token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"purpose\": \"Vehicle Purchase\",\n  \"monthly_income\": 5000\n}"
        },
        "url": {
          "raw": "http://localhost:5000/api/v1/loans/apply",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5000",
          "path": ["api", "v1", "loans", "apply"]
        }
      }
    },
    {
      "name": "6. Validation: Invalid Income (Negative or Non-numeric)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 400 for invalid income\", function () {",
              "    pm.response.to.have.status(400);",
              "});",
              "var jsonData = pm.response.json();",
              "pm.test(\"Error message indicates invalid income\", function () {",
              "    pm.expect(jsonData.error).to.include(\"Invalid monthly income\");",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{customer_token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"amount\": 10000,\n  \"purpose\": \"Medical Expenses\",\n  \"monthly_income\": -500\n}"
        },
        "url": {
          "raw": "http://localhost:5000/api/v1/loans/apply",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5000",
          "path": ["api", "v1", "loans", "apply"]
        }
      }
    },
    {
      "name": "7. Validation: Unauthorized Role (Doctor applying for loan)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 403 Forbidden\", function () {",
              "    pm.response.to.have.status(403);",
              "});",
              "var jsonData = pm.response.json();",
              "pm.test(\"Error indicates role restriction\", function () {",
              "    pm.expect(jsonData.error).to.include(\"Customer role required\");",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{doctor_token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"amount\": 50000,\n  \"purpose\": \"Clinic Equipment\",\n  \"monthly_income\": 12000\n}"
        },
        "url": {
          "raw": "http://localhost:5000/api/v1/loans/apply",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5000",
          "path": ["api", "v1", "loans", "apply"]
        }
      }
    }
  ]
}
